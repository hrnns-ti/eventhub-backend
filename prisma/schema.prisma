generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= ENUMS =================
enum Role {
  SUPERADMIN
  ORGANIZER
  PARTICIPANT
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

// ================= MODELS =================
model User {
  // @db.Uuid memaksa PostgreSQL menggunakan tipe data native UUID, bukan sekadar TEXT
  id            String  @id @default(uuid()) @db.Uuid
  full_name     String
  email         String  @unique // Ditambahkan @unique karena email wajib tunggal untuk login
  password_hash String
  role          Role    @default(PARTICIPANT)
  skills        Json?   @db.JsonB // Memaksa format JSONB sesuai desainmu
  avatar_url    String? // Untuk foto profil
  phone_number  String? @unique // Penting untuk notifikasi tiket via WhatsApp
  institution   String? // Asal Kampus / Sekolah / Perusahaan
  bio           String? @db.Text // Deskripsi singkat diri
  github_link   String? // Sangat relevan untuk portofolio Hackathon
  linkedin_link String?
  

  // Relasi
  events_organized Event[]
  transactions     Transaction[]
  tickets          Ticket[]
  teams_led        Team[]
  team_memberships TeamMember[]

  @@map("users")
}

model Event {
  id                    String   @id @default(uuid()) @db.Uuid
  title                 String
  description           String   @db.Text // Memaksa tipe Text tanpa batas karakter
  organizer_id          String   @db.Uuid
  quota                 Int
  price                 Decimal  @db.Decimal
  registration_deadline DateTime @db.Timestamp()

  // Relasi
  organizer    User          @relation(fields: [organizer_id], references: [id])
  transactions Transaction[]
  tickets      Ticket[]
  teams        Team[]

  @@map("events")
}

model Transaction {
  id                   String        @id @default(uuid()) @db.Uuid
  user_id              String        @db.Uuid
  event_id             String        @db.Uuid
  amount               Decimal       @db.Decimal
  payment_status       PaymentStatus @default(PENDING)
  
  // Kolom-kolom ini saya buat optional (?) karena saat record pertama kali 
  // dibuat (status PENDING), data dari Midtrans/Xendit mungkin belum turun
  payment_url          String?       
  gateway_trx_id       String?       
  payment_method       String?       
  raw_gateway_response Json?         @db.JsonB
  created_at           DateTime      @default(now()) @db.Timestamp()

  // Relasi
  user   User    @relation(fields: [user_id], references: [id])
  event  Event   @relation(fields: [event_id], references: [id])
  ticket Ticket? // Relasi 1-to-0..1 (hanya jika Paid)

  @@map("transactions")
}

model Ticket {
  id             String   @id @default(uuid()) @db.Uuid
  user_id        String   @db.Uuid
  event_id       String   @db.Uuid
  transaction_id String   @unique @db.Uuid
  ticket_code    String   @unique // Wajib unik untuk generate QR Code
  issued_at      DateTime @default(now()) @db.Timestamp()

  // Relasi
  user        User        @relation(fields: [user_id], references: [id])
  event       Event       @relation(fields: [event_id], references: [id])
  transaction Transaction @relation(fields: [transaction_id], references: [id])

  @@map("tickets")
}

model Team {
  id                     String  @id @default(uuid()) @db.Uuid
  event_id               String  @db.Uuid
  team_name              String
  leader_id              String  @db.Uuid
  is_looking_for_members Boolean @default(false)

  // Relasi
  event   Event        @relation(fields: [event_id], references: [id])
  leader  User         @relation(fields: [leader_id], references: [id])
  members TeamMember[]

  @@map("teams")
}

model TeamMember {
  team_id String @db.Uuid
  user_id String @db.Uuid

  // Relasi
  team Team @relation(fields: [team_id], references: [id])
  user User @relation(fields: [user_id], references: [id])

  @@id([team_id, user_id]) // Composite Primary Key dari 2 UUID
  @@map("team_members")
}